+void __afl_map_storfuzz_shm(void) {
+  char *id_str = getenv(STORFUZZ_SHM_ENV_VAR);
+  if (!id_str) return;
+
+#ifdef USEMMAP
+  const char    *shm_file_path = id_str;
+  int            shm_fd = -1;
+  unsigned char *shm_base = NULL;
+
+  shm_fd = shm_open(shm_file_path, O_RDWR, DEFAULT_PERMISSION);
+  if (shm_fd == -1) {
+    fprintf(stderr, "shm_open() failed for storfuzz map\n");
+    exit(1);
+  }
+
+  shm_base = mmap(0, __storfuzz_map_size, PROT_READ | PROT_WRITE, MAP_SHARED,
+                  shm_fd, 0);
+  close(shm_fd);
+
+  if (shm_base == MAP_FAILED) {
+    fprintf(stderr, "mmap() failed for storfuzz map\n");
+    exit(2);
+  }
+
+  __storfuzz_area_ptr = shm_base;
+#else
+  uint32_t shm_id = atoi(id_str);
+  __storfuzz_area_ptr = (uint8_t *)shmat(shm_id, NULL, 0);
+
+  if (!__storfuzz_area_ptr || __storfuzz_area_ptr == (void *)-1) {
+    perror("shmat for storfuzz map");
+    exit(1);
+  }
+#endif
+
+  __storfuzz_area_ptr[0] = 1;
+}
